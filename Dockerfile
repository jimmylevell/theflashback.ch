###############################################################################################
# theflashback - BASE
###############################################################################################
FROM php:8.5-apache as theflashback-base

WORKDIR /usr/share/nginx/html

###############################################################################################
# theflashback - DEPLOY
###############################################################################################
FROM theflashback-base as theflashback-deploy

COPY src/ /var/www/html/

USER www-data

# publish app
EXPOSE 80
